<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>Aviator Style · Crash Game</title>
  <style>
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      margin: 0;
      min-height: 100vh;
      background: radial-gradient(circle at 50% 0%, #1a2a3a, #0a0f1a);
      color: white;
      font-family: 'Segoe UI', 'Arial', sans-serif;
      display: flex;
      justify-content: center;
      align-items: center;
      padding: 16px;
    }

    .game-container {
      max-width: 500px;
      width: 100%;
      background: rgba(10, 20, 30, 0.8);
      backdrop-filter: blur(8px);
      border-radius: 32px;
      padding: 20px;
      box-shadow: 0 20px 40px rgba(0, 0, 0, 0.6), 0 0 0 1px rgba(255, 215, 0, 0.1);
      border: 1px solid rgba(255, 215, 0, 0.2);
    }

    /* Header Stats */
    .stats-bar {
      display: flex;
      justify-content: space-between;
      margin-bottom: 16px;
      font-weight: 600;
      text-shadow: 0 2px 4px black;
    }

    .balance-box {
      background: #0d1b2a;
      padding: 8px 16px;
      border-radius: 40px;
      border: 1px solid #ffd70055;
      box-shadow: inset 0 1px 3px #00000088, 0 4px 6px #00000033;
    }

    .balance-label {
      color: #aab9c9;
      font-size: 12px;
      letter-spacing: 1px;
    }

    .balance-value {
      color: #ffd966;
      font-size: 24px;
      font-weight: 800;
    }

    .players-badge {
      background: #0d1b2a;
      padding: 8px 16px;
      border-radius: 40px;
      display: flex;
      align-items: center;
      gap: 8px;
      border: 1px solid #2a3a4a;
    }

    .live-dot {
      width: 10px;
      height: 10px;
      background: #22c55e;
      border-radius: 50%;
      box-shadow: 0 0 12px #22c55e;
      animation: pulse 1.5s infinite;
    }

    /* Multiplier Display */
    .multiplier-container {
      text-align: center;
      margin-bottom: 12px;
    }

    #multiplier {
      font-size: 72px;
      font-weight: 900;
      background: linear-gradient(135deg, #fff8e7, #ffd966);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
      text-shadow: 0 0 30px #ffbb00aa, 0 4px 8px black;
      letter-spacing: 4px;
      line-height: 1.2;
    }

    .multiplier-label {
      color: #b0c7db;
      text-transform: uppercase;
      letter-spacing: 6px;
      font-size: 12px;
      margin-top: -8px;
    }

    /* Canvas Area */
    .canvas-wrapper {
      background: #030a12;
      border-radius: 24px;
      padding: 8px;
      box-shadow: inset 0 0 20px #000000, 0 8px 0 #040a10;
      border-bottom: 2px solid #ffd70033;
      margin-bottom: 16px;
    }

    canvas {
      display: block;
      width: 100%;
      height: auto;
      background: #051520;
      border-radius: 16px;
      box-shadow: 0 0 0 1px #1e3a5f;
    }

    /* Betting Controls */
    .bet-panel {
      background: #0e1a26;
      border-radius: 20px;
      padding: 18px 16px;
      margin: 16px 0;
      border: 1px solid #2a4055;
    }

    .bet-input-area {
      display: flex;
      align-items: center;
      gap: 8px;
      background: #051016;
      padding: 6px;
      border-radius: 48px;
      border: 1px solid #3a556b;
    }

    .bet-input-area label {
      color: #9bb7d4;
      font-weight: 600;
      padding-left: 12px;
    }

    .bet-input-area input {
      flex: 1;
      background: transparent;
      border: none;
      color: white;
      font-size: 24px;
      font-weight: bold;
      padding: 12px 8px;
      outline: none;
      min-width: 0;
    }

    .bet-input-area input:focus {
      color: #ffd966;
    }

    .quick-bets {
      display: flex;
      gap: 8px;
      margin-top: 12px;
    }

    .chip {
      background: #132433;
      border: 1px solid #3e5f7a;
      color: #c6deed;
      padding: 8px 0;
      border-radius: 30px;
      font-weight: bold;
      font-size: 14px;
      flex: 1;
      text-align: center;
      cursor: pointer;
      transition: all 0.1s;
      box-shadow: 0 3px 0 #0a121c;
    }

    .chip:hover {
      background: #1e3a55;
      border-color: #ffd966;
      color: #ffd966;
      transform: translateY(-1px);
      box-shadow: 0 4px 0 #0a121c;
    }

    .chip:active {
      transform: translateY(2px);
      box-shadow: 0 1px 0 #0a121c;
    }

    /* Action Buttons */
    .action-buttons {
      display: flex;
      gap: 12px;
    }

    .btn {
      flex: 1;
      padding: 18px 10px;
      font-size: 20px;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 2px;
      border: none;
      border-radius: 48px;
      cursor: pointer;
      transition: 0.15s;
      box-shadow: 0 6px 0 #0a121c;
      border: 1px solid #ffffff22;
    }

    .btn-primary {
      background: linear-gradient(145deg, #28a745, #1e7e34);
      color: white;
      text-shadow: 0 1px 2px black;
    }

    .btn-primary:active {
      transform: translateY(4px);
      box-shadow: 0 2px 0 #0a121c;
    }

    .btn-primary:disabled {
      opacity: 0.5;
      transform: none;
      box-shadow: 0 6px 0 #0a121c;
      pointer-events: none;
      filter: grayscale(0.6);
    }

    .btn-cashout {
      background: linear-gradient(145deg, #f59e0b, #d97706);
      color: black;
      text-shadow: 0 1px 0 #ffdd99;
    }

    .btn-cashout:active {
      transform: translateY(4px);
      box-shadow: 0 2px 0 #0a121c;
    }

    .btn-cashout:disabled {
      opacity: 0.4;
      transform: none;
      box-shadow: 0 6px 0 #0a121c;
      pointer-events: none;
    }

    /* History & Info */
    .history-row {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-top: 16px;
      color: #8ba0b5;
    }

    .crashes {
      display: flex;
      gap: 6px;
      flex-wrap: wrap;
    }

    .crash-badge {
      background: #1a2c3d;
      padding: 4px 10px;
      border-radius: 20px;
      font-weight: bold;
      font-size: 14px;
    }

    .crash-badge.green {
      color: #7ee081;
    }

    .crash-badge.red {
      color: #ff7b7b;
    }

    /* Notification */
    .toast-message {
      margin-top: 12px;
      min-height: 30px;
      font-weight: 600;
      color: #ffd966;
      text-align: center;
    }

    @keyframes pulse {
      0% { opacity: 0.6; transform: scale(1); }
      50% { opacity: 1; transform: scale(1.2); background: #4ade80; }
      100% { opacity: 0.6; transform: scale(1); }
    }

    @keyframes shake {
      0%,100% { transform: translateX(0); }
      25% { transform: translateX(-4px); }
      75% { transform: translateX(4px); }
    }

    .shake {
      animation: shake 0.3s ease-in-out;
    }

    /* Mobile friendly */
    @media (max-width: 480px) {
      .game-container { padding: 12px; }
      #multiplier { font-size: 56px; }
      .btn { padding: 14px 8px; font-size: 18px; }
    }
  </style>
</head>
<body>

<div class="game-container">
  <!-- Header -->
  <div class="stats-bar">
    <div class="balance-box">
      <div class="balance-label">BALANCE</div>
      <div class="balance-value" id="balanceDisplay">1000.00</div>
    </div>
    <div class="players-badge">
      <span class="live-dot"></span>
      <span id="onlineCount">2,847</span> <span style="color:#7795ae;">online</span>
    </div>
  </div>

  <!-- Multiplier -->
  <div class="multiplier-container">
    <div id="multiplier">1.00x</div>
    <div class="multiplier-label">CURRENT MULTIPLIER</div>
  </div>

  <!-- Canvas -->
  <div class="canvas-wrapper">
    <canvas id="gameCanvas" width="460" height="280"></canvas>
  </div>

  <!-- Bet Panel -->
  <div class="bet-panel">
    <div class="bet-input-area">
      <label>$</label>
      <input type="number" id="betInput" value="10.00" min="0.10" max="1000" step="0.10">
    </div>
    <div class="quick-bets">
      <div class="chip" data-bet="5">$5</div>
      <div class="chip" data-bet="10">$10</div>
      <div class="chip" data-bet="25">$25</div>
      <div class="chip" data-bet="50">$50</div>
      <div class="chip" data-bet="100">$100</div>
    </div>
  </div>

  <!-- Action Buttons -->
  <div class="action-buttons">
    <button class="btn btn-primary" id="btnBet">Place Bet</button>
    <button class="btn btn-cashout" id="btnCashout" disabled>Cash Out</button>
  </div>

  <!-- History & Messages -->
  <div class="history-row">
    <span>💥 Recent:</span>
    <div class="crashes" id="historyContainer">
      <span class="crash-badge green">2.43x</span>
      <span class="crash-badge red">1.12x</span>
      <span class="crash-badge green">5.67x</span>
    </div>
  </div>
  <div id="messageToast" class="toast-message"></div>
</div>

<script>
(function(){
  "use strict";

  // ----- Canvas & Context -----
  const canvas = document.getElementById("gameCanvas");
  const ctx = canvas.getContext("2d");

  // ----- DOM Elements -----
  const multiplierEl = document.getElementById("multiplier");
  const balanceEl = document.getElementById("balanceDisplay");
  const betInput = document.getElementById("betInput");
  const btnBet = document.getElementById("btnBet");
  const btnCashout = document.getElementById("btnCashout");
  const messageToast = document.getElementById("messageToast");
  const historyContainer = document.getElementById("historyContainer");
  const onlineSpan = document.getElementById("onlineCount");

  // ----- Game State -----
  let balance = 1000.0;
  let currentBet = 10.0;
  let multiplier = 1.00;
  let running = false;
  let crashed = false;
  let cashedOut = false;
  let crashPoint = 1.00;
  
  // Animation
  let animFrame = null;
  let progress = 0.0;        // 0..1 for curve position
  const MAX_PROGRESS = 1.0;
  
  // Graph settings
  const BASE_Y = canvas.height - 30;
  const CURVE_HEIGHT = 200;   // max rise
  
  // Recent crashes (max 6)
  let recentCrashes = [2.43, 1.12, 5.67, 1.85, 3.21, 1.05];
  
  // Fake online count
  let onlineBase = 2847;

  // ----- Helper Functions -----
  function formatMoney(value) {
    return value.toFixed(2);
  }

  function updateBalanceDisplay() {
    balanceEl.textContent = formatMoney(balance);
  }

  function showMessage(text, isGood = true) {
    messageToast.textContent = text;
    messageToast.style.color = isGood ? '#7ee081' : '#ff8a8a';
    setTimeout(() => {
      if (messageToast.textContent === text) messageToast.textContent = '';
    }, 3000);
  }

  // Generate realistic crash point (weighted toward 1.2~3.0, but can go high)
  function generateCrashPoint() {
    let r = Math.random();
    if (r < 0.45) return 1.0 + Math.random() * 1.5;       // 1.0 - 2.5
    else if (r < 0.80) return 2.5 + Math.random() * 3.0;  // 2.5 - 5.5
    else if (r < 0.95) return 5.5 + Math.random() * 8.0;  // 5.5 - 13.5
    else return 13.5 + Math.random() * 20.0;              // rare high
  }

  // Update crash history UI
  function updateHistoryDisplay() {
    let html = '';
    recentCrashes.slice(0, 6).forEach(cp => {
      const cls = cp >= 2.0 ? 'green' : 'red';
      html += `<span class="crash-badge ${cls}">${cp.toFixed(2)}x</span>`;
    });
    historyContainer.innerHTML = html || '<span class="crash-badge">-</span>';
  }

  function addCrashToHistory(cp) {
    recentCrashes.unshift(cp);
    if (recentCrashes.length > 8) recentCrashes.pop();
    updateHistoryDisplay();
  }

  // Update online count with slight variation
  function updateOnlineCount() {
    const variation = Math.floor(Math.random() * 200) - 50;
    onlineBase = Math.max(2100, Math.min(3900, onlineBase + variation));
    onlineSpan.textContent = onlineBase.toLocaleString();
  }
  setInterval(updateOnlineCount, 4000);

  // ----- Drawing (Realistic Aviator trajectory) -----
  function drawScene() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    
    // Draw grid lines (subtle)
    ctx.strokeStyle = '#1a3a55';
    ctx.lineWidth = 0.6;
    for (let i = 0; i <= 5; i++) {
      const y = BASE_Y - (i * (CURVE_HEIGHT / 5));
      ctx.beginPath();
      ctx.moveTo(0, y);
      ctx.lineTo(canvas.width, y);
      ctx.strokeStyle = '#1f3d55';
      ctx.stroke();
    }
    
    // Vertical time markers
    for (let i = 0; i <= 4; i++) {
      const x = i * canvas.width / 4;
      ctx.beginPath();
      ctx.moveTo(x, 0);
      ctx.lineTo(x, canvas.height);
      ctx.strokeStyle = '#152b40';
      ctx.stroke();
    }
    
    // Draw the multiplier curve (exponential growth like aviator)
    const steps = 100;
    const maxX = progress * canvas.width;
    
    ctx.beginPath();
    ctx.moveTo(0, BASE_Y);
    
    for (let i = 0; i <= steps; i++) {
      const t = (i / steps) * progress;  // 0..progress
      // Aviator uses exponential: y = baseY - (e^(k*t) - 1) * heightFactor
      const expGrowth = Math.exp(3.5 * t) - 1;
      const y = BASE_Y - (expGrowth * 0.85);  // control steepness
      const x = t * canvas.width;
      
      if (i === 0) ctx.moveTo(x, y);
      else ctx.lineTo(x, y);
    }
    
    // Draw curve glow
    ctx.shadowColor = '#7eff7e';
    ctx.shadowBlur = 15;
    ctx.strokeStyle = '#8aff80';
    ctx.lineWidth = 4;
    ctx.stroke();
    
    ctx.shadowBlur = 25;
    ctx.strokeStyle = '#b0ffa0';
    ctx.lineWidth = 2.5;
    ctx.stroke();
    
    ctx.shadowBlur = 0;
    
    // Draw the plane / rocket at current position
    const planeX = progress * canvas.width;
    const expY = Math.exp(3.5 * progress) - 1;
    const planeY = BASE_Y - (expY * 0.85);
    
    // Rocket flame
    if (running) {
      ctx.fillStyle = '#ffaa33';
      ctx.shadowColor = '#ff8800';
      ctx.shadowBlur = 15;
      ctx.beginPath();
      ctx.moveTo(planeX - 18, planeY - 3);
      ctx.lineTo(planeX - 28, planeY);
      ctx.lineTo(planeX - 18, planeY + 3);
      ctx.fill();
    }
    
    // Rocket body
    ctx.shadowBlur = 10;
    ctx.shadowColor = '#aaccff';
    ctx.fillStyle = '#e0e7ff';
    ctx.beginPath();
    ctx.ellipse(planeX, planeY, 10, 6, 0, 0, Math.PI * 2);
    ctx.fill();
    
    // Cockpit
    ctx.shadowBlur = 8;
    ctx.fillStyle = '#3b82f6';
    ctx.beginPath();
    ctx.ellipse(planeX + 2, planeY - 2, 4, 3, 0, 0, Math.PI * 2);
    ctx.fill();
    
    ctx.shadowBlur = 0;
    
    // If crashed, red overlay
    if (crashed) {
      ctx.fillStyle = '#ff000030';
      ctx.fillRect(0, 0, canvas.width, canvas.height);
      ctx.font = 'bold 22px "Segoe UI", Arial';
      ctx.fillStyle = '#ffcccc';
      ctx.shadowColor = '#ff0000';
      ctx.shadowBlur = 16;
      ctx.textAlign = "center";
      ctx.fillText('💥 CRASHED 💥', canvas.width/2, canvas.height/2);
      ctx.shadowBlur = 0;
      ctx.textAlign = "left";
    }
  }

  // ----- Animation Loop -----
  function gameLoop() {
    if (!running) {
      drawScene();
      return;
    }
    
    // Increase multiplier smoothly
    multiplier += 0.015;
    // Update progress for curve
    progress = Math.min(MAX_PROGRESS, progress + 0.0065);
    
    // Update display
    multiplierEl.textContent = multiplier.toFixed(2) + 'x';
    
    drawScene();
    
    // Check crash
    if (multiplier >= crashPoint) {
      crash();
      return;
    }
    
    animFrame = requestAnimationFrame(gameLoop);
  }

  // ----- Crash Handler -----
  function crash() {
    if (crashed || !running) return;
    
    running = false;
    crashed = true;
    btnCashout.disabled = true;
    btnBet.disabled = false;
    
    addCrashToHistory(multiplier);
    
    drawScene();
    
    if (!cashedOut) {
      // Lost bet
      balance = Math.max(0, balance - currentBet);
      updateBalanceDisplay();
      showMessage(`💥 Crashed at ${multiplier.toFixed(2)}x · Lost $${formatMoney(currentBet)}`, false);
      
      // Shake effect
      document.querySelector('.game-container').classList.add('shake');
      setTimeout(() => document.querySelector('.game-container').classList.remove('shake'), 400);
    }
    
    cashedOut = false;
    cancelAnimationFrame(animFrame);
    animFrame = null;
    
    // Auto reset state after crash
    btnBet.textContent = 'Place Bet';
  }

  // ----- Cash Out -----
  function cashOut() {
    if (!running || cashedOut || crashed) return;
    
    cashedOut = true;
    running = false;
    crashed = false;  // Not a crash
    
    const winAmount = currentBet * multiplier;
    balance += winAmount;
    updateBalanceDisplay();
    
    btnCashout.disabled = true;
    btnBet.disabled = false;
    btnBet.textContent = 'Place Bet';
    
    showMessage(`✅ Cashed out at ${multiplier.toFixed(2)}x · +$${formatMoney(winAmount)}`, true);
    
    addCrashToHistory(multiplier);
    
    drawScene();
    cancelAnimationFrame(animFrame);
    animFrame = null;
  }

  // ----- Start New Round -----
  function startRound() {
    if (running) return;
    
    // Validate bet
    let bet = parseFloat(betInput.value);
    if (isNaN(bet) || bet < 0.10) bet = 0.10;
    if (bet > balance) {
      showMessage('❌ Insufficient balance', false);
      return;
    }
    currentBet = bet;
    betInput.value = formatMoney(currentBet);
    
    // Reset state
    multiplier = 1.00;
    progress = 0.0;
    running = true;
    crashed = false;
    cashedOut = false;
    crashPoint = generateCrashPoint();
    
    // Update UI
    multiplierEl.textContent = '1.00x';
    btnBet.disabled = true;
    btnBet.textContent = 'FLYING...';
    btnCashout.disabled = false;
    messageToast.textContent = '';
    
    drawScene();
    
    // Start animation
    if (animFrame) cancelAnimationFrame(animFrame);
    animFrame = requestAnimationFrame(gameLoop);
  }

  // ----- Event Listeners -----
  btnBet.addEventListener('click', startRound);
  btnCashout.addEventListener('click', cashOut);
  
  // Quick bet chips
  document.querySelectorAll('.chip').forEach(chip => {
    chip.addEventListener('click', (e) => {
      const betVal = parseFloat(chip.dataset.bet);
      if (!isNaN(betVal)) {
        betInput.value = betVal.toFixed(2);
      }
    });
  });
  
  // Prevent manual bet while running
  betInput.addEventListener('focus', () => {
    if (running) betInput.blur();
  });
  
  // Input validation
  betInput.addEventListener('change', () => {
    let val = parseFloat(betInput.value);
    if (isNaN(val) || val < 0.10) val = 0.10;
    betInput.value = formatMoney(val);
  });

  // Initialize
  updateBalanceDisplay();
  updateHistoryDisplay();
  drawScene();
  
  // Periodic online count update
  setInterval(updateOnlineCount, 3700);
})();
</script>
</body>
</html>
