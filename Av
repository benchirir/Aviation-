using UnityEngine;
using TMPro;

public class CrashGameController : MonoBehaviour
{
    [Header("UI")]
    public TextMeshProUGUI multiplierText;

    [Header("Plane Movement")]
    public Transform plane;
    public Transform startPoint;
    public Transform controlPoint;
    public Transform endPoint;

    float t = 0f;
    float speed = 0.25f;

    float multiplier = 1f;
    float crashPoint;
    bool running = false;
    bool cashedOut = false;

    void Start()
    {
        StartRound();
    }

    void Update()
    {
        if (!running) return;

        MovePlane();

        multiplier += Time.deltaTime * 0.8f;
        multiplierText.text = "x" + multiplier.ToString("F2");

        if (multiplier >= crashPoint)
        {
            Crash();
        }
    }

    void MovePlane()
    {
        if (t < 1f)
        {
            t += Time.deltaTime * speed;

            Vector3 position =
                Mathf.Pow(1 - t, 2) * startPoint.position +
                2 * (1 - t) * t * controlPoint.position +
                Mathf.Pow(t, 2) * endPoint.position;

            plane.position = position;
        }
    }

    public void StartRound()
    {
        t = 0f;
        multiplier = 1f;
        cashedOut = false;
        running = true;

        crashPoint = Random.Range(1.5f, 8f);
    }

    public void CashOut()
    {
        if (!running || cashedOut) return;

        cashedOut = true;
        running = false;

        Debug.Log("Cashed out at x" + multiplier);
    }

    void Crash()
    {
        running = false;

        if (!cashedOut)
        {
            Debug.Log("CRASHED at x" + multiplier);
        }
    }
}
