<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
  <title>Aviator · Betika Clone</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
      background: #0a0e1a;
      color: white;
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 100vh;
    }

    /* Main App Container - Exact Betika dimensions */
    .aviator-app {
      max-width: 390px;
      width: 100%;
      min-height: 844px;
      background: linear-gradient(180deg, #0d1326 0%, #060b18 100%);
      position: relative;
      overflow: hidden;
      border-radius: 0;
      box-shadow: 0 0 40px rgba(0,0,0,0.8);
    }

    /* Status Bar - 02:20 */
    .status-bar {
      display: flex;
      justify-content: space-between;
      padding: 12px 16px 8px;
      font-size: 15px;
      font-weight: 600;
      color: white;
      background: transparent;
    }

    .status-left {
      opacity: 0.9;
    }

    .status-right {
      display: flex;
      gap: 6px;
    }

    /* Navigation Header */
    .nav-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 8px 16px;
      border-bottom: 1px solid rgba(255,255,255,0.05);
    }

    .nav-left {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .back-btn {
      font-size: 24px;
      line-height: 1;
      cursor: pointer;
      opacity: 0.8;
    }

    .game-title {
      display: flex;
      align-items: center;
      gap: 6px;
    }

    .game-title h1 {
      font-size: 20px;
      font-weight: 700;
      letter-spacing: 0.5px;
    }

    .official-badge {
      background: linear-gradient(135deg, #ffd700, #ffb800);
      color: #000;
      font-size: 8px;
      font-weight: 800;
      padding: 2px 6px;
      border-radius: 10px;
      text-transform: uppercase;
    }

    .nav-right {
      display: flex;
      gap: 12px;
    }

    .fullscreen-icon, .menu-icon {
      font-size: 20px;
      cursor: pointer;
      opacity: 0.8;
    }

    /* Balance Bar */
    .balance-bar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 12px 16px;
      background: rgba(0,0,0,0.2);
    }

    .balance-left {
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .balance-amount {
      font-size: 22px;
      font-weight: 700;
      color: #ffd700;
    }

    .currency {
      font-size: 14px;
      color: #8899aa;
      margin-left: 2px;
    }

    .deposit-btn {
      background: #1a5c3a;
      color: white;
      border: none;
      padding: 6px 14px;
      border-radius: 20px;
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
    }

    /* Game Status */
    .game-status-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 8px 16px;
    }

    .finished-badge {
      background: #1e2a3a;
      color: #a0b0c0;
      padding: 4px 12px;
      border-radius: 20px;
      font-size: 13px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    .bet-rush {
      color: #ff6b6b;
      font-weight: 600;
      font-size: 14px;
      display: flex;
      align-items: center;
      gap: 4px;
    }

    /* Rooms Row */
    .rooms-row {
      display: flex;
      padding: 8px 16px;
      gap: 12px;
    }

    .room {
      background: #151e2e;
      padding: 6px 16px;
      border-radius: 20px;
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 13px;
      color: #ff6b6b;
    }

    /* Canvas Game Area */
    .game-canvas-container {
      padding: 0 16px;
      margin: 8px 0;
    }

    canvas {
      width: 100%;
      height: 220px;
      background: #0b1320;
      border-radius: 12px;
      display: block;
      box-shadow: inset 0 0 40px rgba(0,0,0,0.8), 0 2px 0 #1a2a3a;
    }

    /* Multiplier History Row */
    .history-row {
      padding: 12px 16px;
      overflow-x: auto;
      white-space: nowrap;
      scrollbar-width: none;
      -ms-overflow-style: none;
      border-bottom: 1px solid rgba(255,255,255,0.05);
    }

    .history-row::-webkit-scrollbar {
      display: none;
    }

    .multiplier-list {
      display: flex;
      gap: 12px;
    }

    .multiplier-item {
      display: inline-block;
      padding: 4px 12px;
      border-radius: 20px;
      font-weight: 700;
      font-size: 16px;
    }

    .multiplier-green {
      background: #00c853;
      color: white;
    }

    .multiplier-red {
      background: #ff3d00;
      color: white;
    }

    .multiplier-gray {
      background: #2a3a4a;
      color: #a0b0c0;
    }

    /* Partners Banner */
    .partners-banner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 12px 16px;
      background: rgba(0,0,0,0.15);
      border-bottom: 1px solid rgba(255,255,255,0.05);
    }

    .partner-logos {
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .ufc-logo {
      background: #d32f2f;
      color: white;
      font-weight: 800;
      padding: 4px 10px;
      border-radius: 4px;
      font-size: 14px;
      letter-spacing: 1px;
    }

    .aviator-partner {
      color: #ffd700;
      font-weight: 700;
      font-size: 14px;
    }

    .official-partner-text {
      color: #a0b0c0;
      font-size: 10px;
      text-transform: uppercase;
    }

    .spribe-section {
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .spribe-logo {
      background: #1a1a2e;
      padding: 4px 8px;
      border-radius: 4px;
      color: #00d4ff;
      font-weight: 700;
      font-size: 12px;
    }

    .since-text {
      color: #8899aa;
      font-size: 10px;
    }

    /* Betting Panel */
    .betting-panel {
      padding: 16px;
      background: #0d1422;
      margin-top: 4px;
    }

    .bet-tabs {
      display: flex;
      gap: 20px;
      margin-bottom: 20px;
    }

    .tab {
      color: #6a7a8a;
      font-weight: 600;
      font-size: 16px;
      padding-bottom: 8px;
      cursor: pointer;
      border-bottom: 2px solid transparent;
    }

    .tab.active {
      color: white;
      border-bottom: 2px solid #ffd700;
    }

    .bet-input-section {
      margin-bottom: 16px;
    }

    .bet-input-wrapper {
      display: flex;
      align-items: center;
      background: #1a2332;
      border-radius: 8px;
      padding: 8px 16px;
      border: 1px solid #2a3a4a;
    }

    .bet-currency {
      color: #ffd700;
      font-weight: 700;
      font-size: 20px;
      margin-right: 12px;
    }

    .bet-input-wrapper input {
      background: transparent;
      border: none;
      color: white;
      font-size: 28px;
      font-weight: 700;
      width: 100%;
      outline: none;
    }

    .bet-input-wrapper input::placeholder {
      color: #4a5a6a;
    }

    .plus-btn {
      background: #2a3a4a;
      color: white;
      border: none;
      width: 36px;
      height: 36px;
      border-radius: 50%;
      font-size: 24px;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    /* Quick Bet Chips */
    .quick-bet-chips {
      display: flex;
      gap: 8px;
      margin-top: 12px;
    }

    .chip {
      background: #1a2332;
      border: 1px solid #2a3a4a;
      color: white;
      padding: 10px 0;
      border-radius: 8px;
      font-weight: 600;
      font-size: 16px;
      flex: 1;
      text-align: center;
      cursor: pointer;
      transition: all 0.1s;
    }

    .chip:hover {
      background: #2a3a4a;
      border-color: #ffd700;
    }

    /* Bet Button */
    .bet-btn {
      width: 100%;
      background: linear-gradient(180deg, #00c853 0%, #009624 100%);
      border: none;
      color: white;
      font-weight: 800;
      font-size: 20px;
      padding: 18px;
      border-radius: 12px;
      margin-top: 20px;
      cursor: pointer;
      text-transform: uppercase;
      letter-spacing: 2px;
      box-shadow: 0 4px 0 #006414;
      transition: all 0.1s;
    }

    .bet-btn:active {
      transform: translateY(2px);
      box-shadow: 0 2px 0 #006414;
    }

    .bet-btn:disabled {
      opacity: 0.5;
      transform: none;
      box-shadow: 0 4px 0 #006414;
      pointer-events: none;
    }

    /* Cashout Button (hidden by default) */
    .cashout-btn {
      width: 100%;
      background: linear-gradient(180deg, #ff6b6b 0%, #d32f2f 100%);
      border: none;
      color: white;
      font-weight: 800;
      font-size: 20px;
      padding: 18px;
      border-radius: 12px;
      margin-top: 20px;
      cursor: pointer;
      text-transform: uppercase;
      letter-spacing: 2px;
      box-shadow: 0 4px 0 #b71c1c;
      display: none;
    }

    .cashout-btn.active {
      display: block;
    }

    .bet-btn.hidden {
      display: none;
    }

    /* Current Multiplier Display */
    .current-multiplier-overlay {
      position: absolute;
      top: 280px;
      left: 50%;
      transform: translateX(-50%);
      font-size: 48px;
      font-weight: 900;
      color: white;
      text-shadow: 0 0 30px rgba(0,200,83,0.8);
      z-index: 10;
      pointer-events: none;
    }

    /* Animations */
    @keyframes pulse-glow {
      0%, 100% { opacity: 0.8; text-shadow: 0 0 20px #00c853; }
      50% { opacity: 1; text-shadow: 0 0 40px #00c853, 0 0 60px #00c853; }
    }

    .flying .current-multiplier-overlay {
      animation: pulse-glow 0.8s infinite;
    }

    /* Responsive */
    @media (max-width: 390px) {
      .aviator-app {
        min-height: 100vh;
      }
    }
  </style>
</head>
<body>
  <div class="aviator-app" id="app">
    <!-- Status Bar: 02:20 -->
    <div class="status-bar">
      <span class="status-left">02:20</span>
      <div class="status-right">
        <span>📶</span>
        <span>📶</span>
        <span>🔋</span>
      </div>
    </div>

    <!-- Header Navigation -->
    <div class="nav-header">
      <div class="nav-left">
        <span class="back-btn">←</span>
        <div class="game-title">
          <h1>Aviator</h1>
          <span class="official-badge">OFFICIAL</span>
        </div>
      </div>
      <div class="nav-right">
        <span class="fullscreen-icon">⛶</span>
        <span class="menu-icon">⋮</span>
      </div>
    </div>

    <!-- Balance -->
    <div class="balance-bar">
      <div class="balance-left">
        <span class="balance-amount" id="balanceDisplay">0.00</span>
        <span class="currency">KES</span>
      </div>
      <button class="deposit-btn">Deposit</button>
    </div>

    <!-- Game Status -->
    <div class="game-status-row">
      <span class="finished-badge" id="gameStateBadge">FINISHED</span>
      <span class="bet-rush">🔥 Bet Rush</span>
    </div>

    <!-- Rooms -->
    <div class="rooms-row">
      <div class="room">❌ Room #1</div>
      <div class="room">❌ Room #2</div>
      <div class="room">❌ Room #3</div>
    </div>

    <!-- Canvas -->
    <div class="game-canvas-container">
      <canvas id="gameCanvas" width="358" height="220"></canvas>
    </div>

    <!-- Current Multiplier (overlay on canvas) -->
    <div class="current-multiplier-overlay" id="multiplierOverlay">1.00x</div>

    <!-- Multiplier History -->
    <div class="history-row">
      <div class="multiplier-list" id="historyList">
        <span class="multiplier-item multiplier-green">5.36x</span>
        <span class="multiplier-item multiplier-red">1.21x</span>
        <span class="multiplier-item multiplier-green">4.55x</span>
        <span class="multiplier-item multiplier-green">9.34x</span>
        <span class="multiplier-item multiplier-green">7.58x</span>
        <span class="multiplier-item multiplier-red">1.47x</span>
        <span class="multiplier-item multiplier-green">10.03x</span>
        <span class="multiplier-item multiplier-gray">1</span>
      </div>
    </div>

    <!-- Partners -->
    <div class="partners-banner">
      <div class="partner-logos">
        <span class="ufc-logo">UFC</span>
        <span class="aviator-partner">Aviator</span>
        <span class="official-partner-text">OFFICIAL<br>PARTNERS</span>
      </div>
      <div class="spribe-section">
        <span class="spribe-logo">SPRIBE</span>
        <span class="since-text">Official Game<br>Since 2019</span>
      </div>
    </div>

    <!-- Betting Panel -->
    <div class="betting-panel">
      <div class="bet-tabs">
        <span class="tab active">Bet</span>
        <span class="tab">Auto</span>
      </div>

      <div class="bet-input-section">
        <div class="bet-input-wrapper">
          <span class="bet-currency">KSh</span>
          <input type="number" id="betInput" value="10.00" min="1" max="100000" step="1">
          <button class="plus-btn" id="plusBtn">+</button>
        </div>

        <div class="quick-bet-chips">
          <span class="chip" data-bet="100">100</span>
          <span class="chip" data-bet="250">250</span>
          <span class="chip" data-bet="1000">1,000</span>
          <span class="chip" data-bet="25000">25,000</span>
        </div>
      </div>

      <!-- Bet Button -->
      <button class="bet-btn" id="betBtn">Bet</button>
      
      <!-- Cashout Button -->
      <button class="cashout-btn" id="cashoutBtn">Cash Out</button>
    </div>
  </div>

  <script>
    (function() {
      "use strict";

      // Canvas
      const canvas = document.getElementById('gameCanvas');
      const ctx = canvas.getContext('2d');
      
      // UI Elements
      const balanceEl = document.getElementById('balanceDisplay');
      const betInput = document.getElementById('betInput');
      const betBtn = document.getElementById('betBtn');
      const cashoutBtn = document.getElementById('cashoutBtn');
      const multiplierOverlay = document.getElementById('multiplierOverlay');
      const gameStateBadge = document.getElementById('gameStateBadge');
      const historyList = document.getElementById('historyList');
      
      // Game State
      let balance = 5000.00;
      let currentBet = 10.00;
      let multiplier = 1.00;
      let running = false;
      let crashed = false;
      let cashedOut = false;
      let crashPoint = 1.00;
      let progress = 0;
      
      // Animation
      let animFrame = null;
      let historyData = [5.36, 1.21, 4.55, 9.34, 7.58, 1.47, 10.03];
      
      // Canvas dimensions
      const W = 358;
      const H = 220;
      const BASE_Y = H - 25;
      
      // Format currency
      function formatKES(amount) {
        return amount.toFixed(2);
      }
      
      function updateBalance() {
        balanceEl.textContent = formatKES(balance);
      }
      
      // Generate crash point (Aviator distribution)
      function generateCrash() {
        const r = Math.random();
        if (r < 0.40) return 1.0 + Math.random() * 1.2;      // 1.0-2.2
        if (r < 0.75) return 2.2 + Math.random() * 3.0;      // 2.2-5.2
        if (r < 0.93) return 5.2 + Math.random() * 6.0;      // 5.2-11.2
        return 11.2 + Math.random() * 20.0;                  // rare high
      }
      
      // Update history display
      function updateHistory() {
        let html = '';
        historyData.slice(0, 8).forEach(val => {
          const isGreen = val >= 2.0;
          const cls = isGreen ? 'multiplier-green' : 'multiplier-red';
          html += `<span class="multiplier-item ${cls}">${val.toFixed(2)}x</span>`;
        });
        // Add trailing "1" as in screenshot
        html += '<span class="multiplier-item multiplier-gray">1</span>';
        historyList.innerHTML = html;
      }
      
      function addHistory(value) {
        historyData.unshift(value);
        if (historyData.length > 8) historyData.pop();
        updateHistory();
      }
      
      // Drawing function - realistic Aviator style
      function drawScene() {
        ctx.clearRect(0, 0, W, H);
        
        // Grid lines
        ctx.strokeStyle = '#1a2a4a';
        ctx.lineWidth = 0.5;
        for (let i = 0; i <= 4; i++) {
          const y = BASE_Y - (i * 45);
          ctx.beginPath();
          ctx.moveTo(0, y);
          ctx.lineTo(W, y);
          ctx.stroke();
        }
        
        // Draw curve
        if (progress > 0) {
          ctx.beginPath();
          ctx.moveTo(0, BASE_Y);
          
          const steps = 80;
          for (let i = 0; i <= steps; i++) {
            const t = (i / steps) * progress;
            const expY = Math.exp(4.2 * t) - 1;
            const y = BASE_Y - (expY * 0.7);
            const x = t * W;
            
            if (i === 0) ctx.moveTo(x, y);
            else ctx.lineTo(x, y);
          }
          
          // Curve glow
          ctx.shadowColor = '#00ff88';
          ctx.shadowBlur = 20;
          ctx.strokeStyle = '#00e676';
          ctx.lineWidth = 3.5;
          ctx.stroke();
          
          ctx.shadowBlur = 30;
          ctx.strokeStyle = '#69f0ae';
          ctx.lineWidth = 2;
          ctx.stroke();
          
          ctx.shadowBlur = 0;
        }
        
        // Draw plane/rocket
        const planeX = progress * W;
        const expY = Math.exp(4.2 * progress) - 1;
        const planeY = BASE_Y - (expY * 0.7);
        
        if (running) {
          // Flame
          ctx.fillStyle = '#ff9800';
          ctx.shadowColor = '#ff5722';
          ctx.shadowBlur = 15;
          ctx.beginPath();
          ctx.moveTo(planeX - 16, planeY - 2);
          ctx.lineTo(planeX - 26, planeY);
          ctx.lineTo(planeX - 16, planeY + 2);
          ctx.fill();
        }
        
        // Rocket
        ctx.shadowBlur = 12;
        ctx.shadowColor = '#4fc3f7';
        ctx.fillStyle = '#e1f5fe';
        ctx.beginPath();
        ctx.ellipse(planeX, planeY, 9, 5.5, 0, 0, Math.PI * 2);
        ctx.fill();
        
        // Cockpit
        ctx.shadowBlur = 8;
        ctx.fillStyle = '#0288d1';
        ctx.beginPath();
        ctx.ellipse(planeX + 2, planeY - 2, 3.5, 2.5, 0, 0, Math.PI * 2);
        ctx.fill();
        
        ctx.shadowBlur = 0;
        
        // Crash overlay
        if (crashed) {
          ctx.fillStyle = '#ff000040';
          ctx.fillRect(0, 0, W, H);
          ctx.font = 'bold 20px -apple-system, sans-serif';
          ctx.fillStyle = '#ffcdd2';
          ctx.shadowColor = '#ff0000';
          ctx.shadowBlur = 20;
          ctx.textAlign = 'center';
          ctx.fillText('💥 CRASHED 💥', W/2, H/2);
          ctx.shadowBlur = 0;
          ctx.textAlign = 'left';
        }
      }
      
      // Animation loop
      function gameLoop() {
        if (!running) {
          drawScene();
          return;
        }
        
        multiplier += 0.018;
        progress = Math.min(1.0, progress + 0.007);
        
        multiplierOverlay.textContent = multiplier.toFixed(2) + 'x';
        
        drawScene();
        
        if (multiplier >= crashPoint) {
          crash();
          return;
        }
        
        animFrame = requestAnimationFrame(gameLoop);
      }
      
      function crash() {
        if (crashed || !running) return;
        
        running = false;
        crashed = true;
        
        gameStateBadge.textContent = 'CRASHED';
        gameStateBadge.style.background = '#d32f2f';
        
        addHistory(multiplier);
        
        drawScene();
        
        if (!cashedOut) {
          balance = Math.max(0, balance - currentBet);
          updateBalance();
        }
        
        // Reset UI
        betBtn.classList.remove('hidden');
        cashoutBtn.classList.remove('active');
        betBtn.disabled = false;
        
        cancelAnimationFrame(animFrame);
        animFrame = null;
        
        // Reset after 3 seconds
        setTimeout(() => {
          gameStateBadge.textContent = 'FINISHED';
          gameStateBadge.style.background = '#1e2a3a';
          multiplier = 1.00;
          progress = 0;
          multiplierOverlay.textContent = '1.00x';
          crashed = false;
          drawScene();
        }, 3000);
      }
      
      function cashOut() {
        if (!running || cashedOut || crashed) return;
        
        cashedOut = true;
        running = false;
        
        const winAmount = currentBet * multiplier;
        balance += winAmount;
        updateBalance();
        
        gameStateBadge.textContent = 'CASHED OUT';
        gameStateBadge.style.background = '#00c853';
        
        addHistory(multiplier);
        
        betBtn.classList.remove('hidden');
        cashoutBtn.classList.remove('active');
        betBtn.disabled = false;
        
        drawScene();
        cancelAnimationFrame(animFrame);
        animFrame = null;
        
        setTimeout(() => {
          gameStateBadge.textContent = 'FINISHED';
          gameStateBadge.style.background = '#1e2a3a';
        }, 3000);
      }
      
      function startRound() {
        if (running) return;
        
        let bet = parseFloat(betInput.value);
        if (isNaN(bet) || bet < 1) bet = 1;
        if (bet > balance) {
          alert('Insufficient balance');
          return;
        }
        
        currentBet = bet;
        
        multiplier = 1.00;
        progress = 0.0;
        running = true;
        crashed = false;
        cashedOut = false;
        crashPoint = generateCrash();
        
        multiplierOverlay.textContent = '1.00x';
        gameStateBadge.textContent = 'FLYING';
        gameStateBadge.style.background = '#ff9800';
        
        betBtn.classList.add('hidden');
        cashoutBtn.classList.add('active');
        
        drawScene();
        
        if (animFrame) cancelAnimationFrame(animFrame);
        animFrame = requestAnimationFrame(gameLoop);
      }
      
      // Event Listeners
      betBtn.addEventListener('click', startRound);
      cashoutBtn.addEventListener('click', cashOut);
      
      document.getElementById('plusBtn').addEventListener('click', () => {
        let val = parseFloat(betInput.value) || 10;
        betInput.value = (val + 10).toFixed(2);
      });
      
      document.querySelectorAll('.chip').forEach(chip => {
        chip.addEventListener('click', () => {
          const val = parseFloat(chip.dataset.bet);
          if (!isNaN(val)) {
            betInput.value = val.toFixed(2);
          }
        });
      });
      
      // Initialize
      updateBalance();
      updateHistory();
      drawScene();
      
      // Tab switching (visual only)
      document.querySelectorAll('.tab').forEach(tab => {
        tab.addEventListener('click', function() {
          document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
          this.classList.add('active');
        });
      });
      
      // Fullscreen toggle
      document.querySelector('.fullscreen-icon').addEventListener('click', () => {
        if (!document.fullscreenElement) {
          document.documentElement.requestFullscreen();
        } else {
          document.exitFullscreen();
        }
      });
      
    })();
  </script>
</body>
</html>
